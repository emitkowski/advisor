  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --rawfile content remote.md '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":$content}}'",
            "statusMessage": "Loading remote.md..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q 'blade' && vendor/bin/sail artisan view:clear 2>/dev/null || true",
            "statusMessage": "Clearing blade view cache..."
          }
        ]
      }
    ]
  }
